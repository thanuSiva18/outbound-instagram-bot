# ============================================================
#  Outbound WhatsApp Console — environment config
#  Copy this file to ".env.local" and fill in real values.
#  With NOTHING filled in, the app still runs in SIMULATION
#  MODE: you can send from the dashboard and get auto-replies,
#  so you can demo the full UX before Meta is connected.
# ============================================================

# ---- Meta WhatsApp Cloud API (leave blank for simulation mode) ----
# From Meta Developer Portal -> WhatsApp -> API Setup
WHATSAPP_PHONE_NUMBER_ID=900006843195557
# Permanent System User token (NOT the 24h temporary one)
WHATSAPP_TOKEN=
# Graph API version
WHATSAPP_GRAPH_VERSION=v19.0

# ---- Webhook verification (you choose this string) ----
# Paste the SAME string into Meta -> WhatsApp -> Configuration -> Verify Token
WHATSAPP_VERIFY_TOKEN=outbound_whatsapp_verify_2026

# ---- AI auto-reply (optional). Priority: Anthropic > OpenAI > scripted ----
# Anthropic (Claude) — recommended
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001
# OpenAI fallback (your current n8n bot uses this)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Google Sheet lead capture (optional) ----
# Reuses the live bot's `whatsapp leads` tab (13-col Rahul schema, match key ig_user_id).
# Auth = a Google SERVICE ACCOUNT: create one in Google Cloud, enable the Sheets API,
# then share the spreadsheet with the service-account email as Editor.
SHEET_ID=1T89p6LhpjwNJ_kqh5WT6DAj3Jt242Gs1JaTNzDCJJio
SHEET_TAB=whatsapp leads
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private key with literal \n (or real newlines in quotes):
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
