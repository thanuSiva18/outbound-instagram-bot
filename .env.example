# ─────────────────────────────────────────────────────────────────────────
# Outbound Travelers · Instagram Lead Bot — environment placeholders
# Copy to .env and fill in REAL values. NEVER commit the filled .env.
# (See CLAUDE.md §11 — secrets live here + in n8n's credential store only.)
# ─────────────────────────────────────────────────────────────────────────

# Token Claude Code reads when adding the n8n-mcp HTTP server (CLAUDE.md §4.0).
# ⚠️ This was shared in plaintext during planning — regenerate in n8n before go-live.
N8N_MCP_TOKEN=

# Fallback only: run n8n-mcp locally (npx n8n-mcp) instead of the remote endpoint.
N8N_API_URL=
N8N_API_KEY=

# NOTE: The OpenAI API key and Google Sheets OAuth credential are NOT stored here.
# They live inside n8n's own credential store (created in the n8n UI by Faheem).
